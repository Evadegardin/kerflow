---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Contact - KerFlow Clamart"
  description="Adresse, acces, horaires et contact KerFlow a Clamart."
>
  <SiteHeader />
  <main>
    <section class="page-hero section-pad accent-location">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>Venir chez <em>KerFlow</em>.</h1>
      </div>
      <p>Une page simple pour trouver l'adresse, poser une question, reserver, demander un rendez-vous ou proposer une demande professionnelle.</p>
    </section>

    <section class="visit section-pad">
      <div class="visit-grid">
        <div>
          <p class="eyebrow">Infos pratiques</p>
          <h2>A deux pas<br />de la gare<br /><em>de Clamart.</em></h2>
          <div class="info-list">
            <div><span>Adresse</span><p>12 rue de la Roche<br />92140 Clamart</p></div>
            <div><span>Acces</span><p>Transilien N - Clamart (5 min a pied)<br />Tramway T6 - Mairie de Clamart<br />Parking rue Pierre Brossolette</p></div>
            <div><span>Horaires</span><p>Mardi → samedi - 9h00 - 20h00<br />Lundi & dimanche - ferme</p></div>
            <div><span>Contact</span><p>bonjour@kerflow.fr<br />01 46 38 12 34</p></div>
          </div>
        </div>
        <div class="map-card">
          <div class="map-illustration">
            <svg viewBox="0 0 400 280" aria-label="Carte illustree entre la gare de Clamart et KerFlow">
              <path d="M-20 80C80 60 160 100 220 80C300 60 380 100 420 80"></path>
              <path d="M-20 160C60 180 140 140 220 170C300 195 360 170 420 180"></path>
              <path d="M80-10C100 60 90 140 130 220C140 250 130 280 140 300"></path>
              <path d="M240-10C260 80 230 160 270 240C280 270 285 290 280 310"></path>
              <path class="rail" d="M0 230C80 240 200 220 400 250"></path>
              <rect x="158" y="210" width="44" height="20"></rect>
              <text x="180" y="262">GARE DE CLAMART</text>
              <circle class="pin" cx="260" cy="100" r="6"></circle>
              <circle class="pin-ring" cx="260" cy="100" r="14"></circle>
              <text class="label" x="280" y="104">KerFlow</text>
              <text x="280" y="122">12 RUE DE LA ROCHE</text>
              <path class="walk" d="M180 215C200 180 230 140 256 105"></path>
            </svg>
            <div class="map-caption mono"><span>Clamart - 92140</span><span>5 min a pied de la gare</span></div>
          </div>
          <footer>
            <span>Voir l'itineraire</span>
            <a class="btn-line" href="https://www.google.com/maps" target="_blank" rel="noreferrer">Ouvrir Google Maps</a>
          </footer>
        </div>
      </div>
    </section>

    <section id="newsletter" class="final-cta section-pad">
      <div>
        <h2>Une question,<br />une premiere visite,<br /><em>une demande pro</em> ?</h2>
        <form class="final-newsletter">
          <p>Le formulaire final pourra router les demandes : question generale, premiere visite, rendez-vous sante ou soin, demande de location.</p>
          <label><span class="sr-only">Votre adresse e-mail</span><input type="email" placeholder="votre adresse e-mail" /></label>
          <div class="actions final-newsletter-actions">
            <button class="btn btn-accent" type="submit">Etre recontacte <span aria-hidden="true">→</span></button>
          </div>
        </form>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
